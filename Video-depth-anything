{"metadata":{"kernelspec":{"language":"python","display_name":"Python 3","name":"python3"},"language_info":{"name":"python","version":"3.12.13","mimetype":"text/x-python","codemirror_mode":{"name":"ipython","version":3},"pygments_lexer":"ipython3","nbconvert_exporter":"python","file_extension":".py"},"kaggle":{"accelerator":"nvidiaTeslaT4","dataSources":[{"sourceType":"datasetVersion","sourceId":16651220}],"dockerImageVersionId":31401,"isInternetEnabled":true,"language":"python","sourceType":"script","isGpuEnabled":true}},"nbformat_minor":4,"nbformat":4,"cells":[{"cell_type":"code","source":"# %% [code]\nimport os\nimport glob\nimport subprocess\nimport sys\n\n# 1. Paths (Pointed directly to your custom dataset slug)\nINPUT_DIR = \"/kaggle/input/insect-videos\"\nOUTPUT_DIR = \"/kaggle/working/output\"\nCODE_DIR = \"/kaggle/working/Video-Depth-Anything\"\n\nos.makedirs(OUTPUT_DIR, exist_ok=True)\nsubprocess.run([\"git\", \"clone\", \"https://github.com/DepthAnything/Video-Depth-Anything.git\", CODE_DIR], check=True)\n\n# 2. Redirect working directory to the models folder\nos.chdir(CODE_DIR)\n\n# 3. Handle model checkpoint download dynamically on Kaggle\nCHECKPOINT_DIR = os.path.join(CODE_DIR, \"checkpoints\")\nos.makedirs(CHECKPOINT_DIR, exist_ok=True)\nCHECKPOINT_PATH = os.path.join(CHECKPOINT_DIR, \"video_depth_anything_vitl.pth\")\nprint(\"Downloading model weights directly to Kaggle GPU instance anonymously...\")\npublic_url = \"https://huggingface.co/depth-anything/Video-Depth-Anything-Large/resolve/main/video_depth_anything_vitl.pth\"\nsubprocess.run([\"curl\", \"-L\", public_url, \"-o\", CHECKPOINT_PATH], check=True)\n\n# 4. Find and target video assets (Searching inside subfolders)\nvideo_extensions = ['/**/*.mp4', '/**/*.avi', '/**/*.mov', '/**/*.mkv', '/**/*.MP4']\ninput_videos = []\nfor ext in video_extensions:\n    input_videos.extend(glob.glob(INPUT_DIR + ext, recursive=True))\n\nif not input_videos:\n    print(f\"No target videos detected in {INPUT_DIR}.\")\n    sys.exit(0)\n\nprint(f\"Discovered {len(input_videos)} processing target(s).\\n\")\n\n# 5. Processing Loop\nfor idx, video_path in enumerate(input_videos, 1):\n    video_name = os.path.basename(video_path)\n    \n    # Track the folder hierarchy (Adrian, Dickinson, Najmeh, etc.)\n    relative_path = os.path.relpath(os.path.dirname(video_path), INPUT_DIR)\n    \n    # Recreate the directory structure in output\n    target_output_dir = os.path.join(OUTPUT_DIR, relative_path)\n    os.makedirs(target_output_dir, exist_ok=True)\n\n    print(f\"--- Processing [{idx}/{len(input_videos)}]: {relative_path}/{video_name} ---\")\n\n    cmd = [\n        sys.executable, \"run.py\",\n        \"--input_video\", video_path,\n        \"--output_dir\", target_output_dir,\n        \"--encoder\", \"vitl\",\n        \"--input_size\", \"266\",\n        \"--max_len\", \"16\",\n        \"--target_fps\", \"22\"\n    ]\n\n    try:\n        subprocess.run(cmd, check=True)\n        print(f\"Successfully rendered depth to {relative_path}/\\n\")\n    except subprocess.CalledProcessError as e:\n        print(f\"Failure processing {video_name}: {e}\\n\")","metadata":{"_uuid":"9da5087f-cab5-4c4c-ad34-30e0bfec7521","_cell_guid":"972e9894-ef63-4c60-8660-39d280273604","trusted":true,"collapsed":false,"jupyter":{"outputs_hidden":false}},"outputs":[],"execution_count":null}]}